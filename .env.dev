APP_ENV=development
APP_PORT=8080
STORAGE_BACKEND=redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=subtitle-delivery
MAX_SUBTITLE_SIZE_BYTES=307200
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PROBE_ALLOWED_IPS=127.0.0.1,::1
HEALTH_PROTECTION_ENABLED=true
CACHE_TTL=10m
RATE_LIMIT_BURST=60
RATE_LIMIT_WINDOW=1m
